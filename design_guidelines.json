{
  "brand_identity": {
    "name": "Esencia Mini Pancakes & Coffee",
    "core_values": ["Artisan", "Warmth", "Simplicity", "Indulgence"],
    "voice": "Elegant, welcoming, and efficient",
    "persona": "The sophisticated barista who remembers your order"
  },
  "typography": {
    "font_family": {
      "headings": "PlayfairDisplay_700Bold",
      "subheadings": "PlayfairDisplay_600SemiBold",
      "body": "DMSans_400Regular",
      "body_bold": "DMSans_700Bold",
      "caption": "DMSans_500Medium"
    },
    "font_loading_instructions": "Use expo-font to load 'PlayfairDisplay' and 'DMSans' from Google Fonts via expo-google-fonts packages.",
    "sizes": {
      "h1": 32,
      "h2": 24,
      "h3": 20,
      "body": 16,
      "small": 14,
      "caption": 12
    }
  },
  "colors": {
    "palette": {
      "primary": "#D4A574",
      "primary_foreground": "#FFFFFF",
      "secondary": "#1A1A1A",
      "secondary_foreground": "#FFFFFF",
      "accent": "#C9A96E",
      "background": "#FAFAF9",
      "surface": "#FFFFFF",
      "surface_highlight": "#F5F5F0",
      "text_primary": "#1A1A1A",
      "text_secondary": "#6B6B6B",
      "border": "#E5E5E0",
      "success": "#5D7853",
      "error": "#B94A48",
      "warning": "#E6B800"
    },
    "gradients": {
      "gold_rush": ["#C9A96E", "#E6C88B"],
      "coffee_fade": ["#1A1A1A", "#333333"]
    }
  },
  "spacing": {
    "xs": 4,
    "s": 8,
    "m": 16,
    "l": 24,
    "xl": 32,
    "xxl": 48,
    "container_padding": 20
  },
  "layout": {
    "border_radius": {
      "s": 8,
      "m": 16,
      "l": 24,
      "pill": 999
    },
    "shadows": {
      "soft": {
        "shadowColor": "#000",
        "shadowOffset": { "width": 0, "height": 4 },
        "shadowOpacity": 0.05,
        "shadowRadius": 12,
        "elevation": 2
      },
      "medium": {
        "shadowColor": "#000",
        "shadowOffset": { "width": 0, "height": 8 },
        "shadowOpacity": 0.1,
        "shadowRadius": 24,
        "elevation": 5
      }
    }
  },
  "components": {
    "Button": {
      "base": {
        "height": 56,
        "borderRadius": 999,
        "justifyContent": "center",
        "alignItems": "center",
        "flexDirection": "row",
        "gap": 8
      },
      "primary": {
        "backgroundColor": "#1A1A1A"
      },
      "secondary": {
        "backgroundColor": "#D4A574"
      },
      "outline": {
        "backgroundColor": "transparent",
        "borderWidth": 1,
        "borderColor": "#1A1A1A"
      },
      "ghost": {
        "backgroundColor": "transparent"
      }
    },
    "Card": {
      "base": {
        "backgroundColor": "#FFFFFF",
        "borderRadius": 24,
        "padding": 20,
        "borderWidth": 1,
        "borderColor": "#F0F0F0"
      }
    },
    "Input": {
      "base": {
        "height": 56,
        "backgroundColor": "#F5F5F0",
        "borderRadius": 16,
        "paddingHorizontal": 16,
        "fontSize": 16,
        "color": "#1A1A1A"
      },
      "focus": {
        "borderWidth": 1,
        "borderColor": "#D4A574",
        "backgroundColor": "#FFFFFF"
      }
    }
  },
