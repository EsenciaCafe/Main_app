  "instructions_to_main_agent": [
    "1. CREATE A THEME FILE: Create 'src/constants/theme.js' and export the colors, spacing, and typography objects defined above. Import this in every component.",
    "2. NO TAILWIND: This is a standard Expo React Native project. Use 'StyleSheet.create' and refer to the theme constants.",
    "3. FONTS: Install 'expo-font', '@expo-google-fonts/playfair-display', and '@expo-google-fonts/dm-sans'. Load them in the root layout.",
    "4. ICONS: Use '@expo/vector-icons' (specifically Feather or Ionicons) for a clean look.",
    "5. NAVIGATION: Use 'expo-router'. Create a tab layout for the main app and a stack layout for auth.",
    "6. ADMIN PANEL: Should be a separate tab or a hidden section accessible only to specific users.",
    "7. BENTO GRID: On the Home screen, use a flexible grid layout (View with flexDirection: row, flexWrap: wrap) to create the dashboard effect.",
    "8. QR CODE: Use 'react-native-qrcode-svg' for generation and 'expo-camera' for scanning.",
    "9. DATA TEST ID: Add 'testID' prop to all TouchableOpacity and TextInput components for testing."
  ],
  "UNIVERSAL_GUIDELINES_FOR_MAIN_AGENT": [
    "Avoid gradients on text.",
    "Use 2-3x more spacing than typical defaults.",
    "Buttons must be at least 48px height (ideally 56px).",
    "Never use pure black (#000000) for backgrounds; use #1A1A1A or similar.",
    "Animations: Use 'react-native-reanimated' for layout transitions (LayoutAnimation.configureNext) if possible, or simple LayoutAnimation API."
  ]
}